{
  "name": "grok-build-lab",
  "private": true,
  "version": "0.3.1",
  "description": "Grok Build Lab — local docs + native float shell + Ship deck for Grok Build (SpaceXAI). Path docs/architecture-lab is historical; product name is Grok Build Lab.",
  "license": "Apache-2.0",
  "scripts": {
    "start": "bash ./serve.sh",
    "serve": "bash ./serve.sh",
    "status": "bash ./scripts/status-xai-check.sh",
    "status:strict": "bash ./scripts/status-xai-check.sh --strict",
    "prepush": "bash ./scripts/status-xai-check.sh --strict",
    "install-pre-push": "bash ./scripts/install-pre-push-hook.sh",
    "desktop": "bash ./native/launch.sh float",
    "desktop:lab": "bash ./native/launch.sh lab",
    "desktop:tui": "bash ./native/launch.sh tui",
    "desktop:app": "bash ./native/build-mac-app.sh",
    "desktop:electron": "ARCH_LAB_FORCE_ELECTRON=1 bash ./desktop/launch-mac.sh"
  }
}
